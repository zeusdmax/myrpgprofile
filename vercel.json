// IE development tips
const IE_DEV=[
  'Practica la identificación de emociones: ponle nombre a lo que sientes en el momento, no después.',
  'Trabaja la empatía activa: en conversaciones difíciles, reformula lo que escuchas antes de responder.',
  'Lleva un registro emocional breve (3 min/día): qué sentiste, qué lo provocó, cómo reaccionaste.',
];

// ═══════════════ STATE ═══════════════
let user={},ans={},nts={},cur=0;

// ═══════════════ UTILS ═══════════════
function go(id){
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active');s.style.display='none'});
  const el=document.getElementById(id);
  el.style.display='flex';
  el.style.flexDirection='column';
  requestAnimationFrame(()=>el.classList.add('active'));
  window.scrollTo({top:0,behavior:'smooth'});
}

function toInstr(){
  const n=document.getElementById('iname').value.trim(),a=document.getElementById('iage').value.trim(),s=document.getElementById('isex').value,e=document.getElementById('errbox');
  if(!n){e.style.display='block';e.textContent='Por favor ingresa tu nombre.';return}
  if(!a||+a<14||+a>99){e.style.display='block';e.textContent='Ingresa una edad válida (14-99).';return}
  if(!s){e.style.display='block';e.textContent='Por favor selecciona tu sexo biológico.';return}
  e.style.display='none';
  user={name:n,age:+a,sex:s,email:document.getElementById('iemail').value.trim()};
  document.getElementById('dchips').innerHTML=DIMS.map(d=>`<span class="chip">${d.tomo}: ${d.name}</span>`).join('');
  go('instructions');
}

function startQ(){cur=0;ans={};nts={};renderD();go('questionnaire')}

function renderD(){
  const d=DIMS[cur];
  document.getElementById('dtag').textContent=`${d.tomo.toUpperCase()} · ATRIBUTO ${cur+1} DE ${DIMS.length}`;
  document.getElementById('dname').textContent=d.name;
  document.getElementById('dflavor').textContent=d.flavor;
  // Icon
  const box=document.getElementById('dibox');
  box.innerHTML=`<div style="color:var(--gold2)">${ICONS[d.icon]||''}</div>`;
  document.getElementById('bprev').style.visibility=cur===0?'hidden':'visible';
  document.getElementById('bnext').textContent=cur===DIMS.length-1?'Ver mi clase →':'Siguiente →';
  // Progress
  const tot=Object.keys(ans).length,pct=Math.round((tot/(DIMS.length*5))*100);
  document.getElementById('plabel').textContent=`${d.tomo} de VII`;
  document.getElementById('ppct').textContent=pct+'%';
  document.getElementById('pfill').style.width=pct+'%';
  // Items
  const wrap=document.getElementById('iwrap');wrap.innerHTML='';
  d.items.forEach((item,i)=>{
    const k=`${d.id}_${i}`,v=ans[k],nt=nts[k]||'',bl=document.createElement('div');
    bl.className='iblock'+(v!==undefined?' done':'');bl.id='b'+k;
    bl.innerHTML=`
      <div class="imeta">${d.tomo} · Afirmación ${cur*5+i+1} de 35</div>
      <div class="itext">${item.t}</div>
      <div class="lrow">${[1,2,3,4,5].map(n=>`<button class="lb${v===n?' on':''}" onclick="pick('${k}',${n},this)">${n}</button>`).join('')}</div>
      <div class="llabels"><span>Muy en desacuerdo</span><span>Neutral</span><span>Muy de acuerdo</span></div>
      <div class="note-toggle${nt?' open':''}" id="nt${k}" onclick="tn('${k}')">Agregar nota personal</div>
      <div class="narea" id="n${k}" style="${nt?'display:block':''}"><textarea rows="2" maxlength="200" placeholder="¿Por qué elegiste este puntaje? (opcional)" oninput="sn('${k}',this.value)">${nt}</textarea></div>`;
    wrap.appendChild(bl);
  });
  upNav();
}

function pick(k,v,btn){
  ans[k]=v;document.getElementById('b'+k).classList.add('done');
  document.getElementById('b'+k).querySelectorAll('.lb').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');upNav();
  const tot=Object.keys(ans).length,pct=Math.round((tot/(DIMS.length*5))*100);
  document.getElementById('ppct').textContent=pct+'%';
  document.getElementById('pfill').style.width=pct+'%';
}
function sn(k,v){nts[k]=v}
function tn(k){
  const el=document.getElementById('n'+k),nt=document.getElementById('nt'+k);
  const open=el.style.display==='block';
  el.style.display=open?'none':'block';nt.classList.toggle('open',!open);
  if(!open)el.querySelector('textarea').focus();
}
function upNav(){
  const d=DIMS[cur],done=d.items.filter((_,i)=>ans[`${d.id}_${i}`]!==undefined).length;
  document.getElementById('ninfo').textContent=`${done}/${d.items.length} respondidas`;
}
function prevD(){if(cur>0){cur--;renderD();window.scrollTo(0,0)}}
function nextD(){
  const d=DIMS[cur],m=d.items.filter((_,i)=>ans[`${d.id}_${i}`]===undefined).length;
  if(m>0){alert(`Por favor responde las ${m} afirmación(es) pendientes.`);return}
  if(cur<DIMS.length-1){cur++;renderD();window.scrollTo(0,0)}else showRes();
}

function scores(){
  const s={};
  DIMS.forEach(d=>{let sum=0;d.items.forEach((item,i)=>{let v=ans[`${d.id}_${i}`]||3;if(item.v)v=6-v;sum+=v});s[d.id]=Math.round(((sum-d.items.length)/(d.items.length*4))*100)});
  return s;
}
function ieScore(s){return Math.round(s.empatia*.35+s.resiliencia*.25+s.voluntad*.20+s.accion*.10+s.vision*.10)}
function imScores(s){return IM.map(im=>({...im,score:Math.round(im.calc(s))})).sort((a,b)=>b.score-a.score)}
function archetype(s){
  const top3=Object.entries(s).sort((a,b)=>b[1]-a[1]).slice(0,3).map(e=>e[0]);
  let best=null,bs=-1;
  ARCH.forEach(a=>{let m=0;a.dims.forEach((d,i)=>{const r=top3.indexOf(d);if(r>=0)m+=(3-r)});if(m>bs){bs=m;best=a}});
  return best;
}


async function guardarResultados(s, arch, nm, ie, im) {
  try {
    await fetch('/api/guardar', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        nombre: user.name,
        edad: user.age,
        sexo: user.sex,
        correo: user.email || null,
        arquetipo: nm,
        voluntad: s.voluntad,
        vision: s.vision,
        resiliencia: s.resiliencia,
        empatia: s.empatia,
        accion: s.accion,
        estructura: s.estructura,
        influencia: s.influencia,
        ie: ie,
        im_predominante: im[0]?.name || null,
        im_menor: im[im.length-1]?.name || null
      })
    });
  } catch(e) {
    // Guardar en silencio, no interrumpir la experiencia del usuario
    console.log('No se pudieron guardar los resultados:', e);
  }
}

function showRes(){
  const s=scores(),arch=archetype(s),ie=ieScore(s),im=imScores(s);
  document.body.className=arch.css;
  const nm=user.sex==='F'?arch.nameF:arch.nameM;
  // Hero
  document.getElementById('archIconWrap').innerHTML=`<div style="color:var(--acc2)">${ICONS[arch.iconKey]||''}</div>`;
  document.getElementById('acname').textContent=nm;
  document.getElementById('acsub').textContent=arch.sub;
  document.getElementById('acdesc').textContent=arch.desc;
  document.getElementById('swrow').innerHTML=arch.str.map(x=>`<span class="swtag s">✓ ${x}</span>`).join('')+arch.wk.map(x=>`<span class="swtag w">△ ${x}</span>`).join('');
  document.getElementById('motto').textContent=arch.motto.replace('{{n}}',user.name);
  go('results');
  setTimeout(()=>{
    drawRadar(s,arch);bldScores(s);bldIE(ie);bldIM(im);bldCompat(arch);bldRec(arch);bldAdv(arch,nm);
    // Build Lyra profile context
    const imArr=im;
    buildLyraUI({
      name:user.name, age:user.age, sex:user.sex,
      archName:nm,
      scores:s,
      ie:ie,
      imTop: imArr[0]?imArr[0].name:'—',
      imBot: imArr[imArr.length-1]?imArr[imArr.length-1].name:'—',
    });
    // Guardar resultados en base de datos
    guardarResultados(s, arch, nm, ie, imArr);
  },180);
}

function drawRadar(s,arch){
  const cv=document.getElementById('radar'),ctx=cv.getContext('2d'),sz=cv.width,cx=sz/2,cy=sz/2,r=sz*.33,n=DIMS.length;
  ctx.clearRect(0,0,sz,sz);
  for(let ring=1;ring<=4;ring++){
    ctx.beginPath();for(let i=0;i<=n;i++){const a=(i*2*Math.PI/n)-Math.PI/2,pr=r*ring/4;i===0?ctx.moveTo(cx+pr*Math.cos(a),cy+pr*Math.sin(a)):ctx.lineTo(cx+pr*Math.cos(a),cy+pr*Math.sin(a))}
    ctx.closePath();ctx.strokeStyle='rgba(232,200,74,0.1)';ctx.lineWidth=1;ctx.stroke();
  }
  for(let i=0;i<n;i++){const a=(i*2*Math.PI/n)-Math.PI/2;ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+r*Math.cos(a),cy+r*Math.sin(a));ctx.strokeStyle='rgba(232,200,74,0.08)';ctx.lineWidth=1;ctx.stroke()}
  const vals=DIMS.map(d=>(s[d.id]||0)/100);
  ctx.beginPath();for(let i=0;i<=n;i++){const idx=i%n,a=(idx*2*Math.PI/n)-Math.PI/2,pr=r*vals[idx];i===0?ctx.moveTo(cx+pr*Math.cos(a),cy+pr*Math.sin(a)):ctx.lineTo(cx+pr*Math.cos(a),cy+pr*Math.sin(a))}
  ctx.closePath();
  const ac=getComputedStyle(document.body).getPropertyValue('--acc').trim()||'#e8c84a';
  ctx.fillStyle=ac+'20';ctx.fill();ctx.strokeStyle=ac;ctx.lineWidth=2;ctx.stroke();
  ctx.save();ctx.font='500 11.5px "Crimson Pro",serif';ctx.textAlign='center';ctx.textBaseline='middle';
  DIMS.forEach((d,i)=>{
    const a=(i*2*Math.PI/n)-Math.PI/2,pr=r*vals[i];
    ctx.beginPath();ctx.arc(cx+pr*Math.cos(a),cy+pr*Math.sin(a),4.5,0,2*Math.PI);
    ctx.fillStyle=d.color;ctx.fill();ctx.strokeStyle='#050b18';ctx.lineWidth=2;ctx.stroke();
    ctx.fillStyle=d.color;ctx.shadowColor=d.color;ctx.shadowBlur=6;
    ctx.fillText(d.name,cx+(r+27)*Math.cos(a),cy+(r+27)*Math.sin(a));ctx.shadowBlur=0;
  });
  ctx.restore();
}

function bldScores(s){
  const g=document.getElementById('sgrid');g.innerHTML='';
  DIMS.forEach(d=>{
    const v=s[d.id];const c=document.createElement('div');c.className='scard';
    c.innerHTML=`<div class="sclabel" style="color:${d.color}">${d.name}</div><div class="sctrack"><div class="scfill" id="sf${d.id}" style="width:0%;background:linear-gradient(90deg,${d.color}88,${d.color})"></div></div><div class="scval" style="color:${d.color};text-shadow:0 0 12px ${d.color}66">${v}<small>/100</small></div>`;
    g.appendChild(c);setTimeout(()=>{const f=document.getElementById('sf'+d.id);if(f)f.style.width=v+'%'},220);
  });
}

function bldIE(ie){
  document.getElementById('ieval').textContent=ie;
  const c=207,off=c-(c*(ie/100));
  setTimeout(()=>{const arc=document.getElementById('iearc');if(arc)arc.style.strokeDashoffset=off},320);
  const d=ie>=75?`Tu índice IE de ${ie} indica alta capacidad para percibir, usar y regular emociones propias y ajenas. Se expresa principalmente a través de tu Empatía y Resiliencia.`:ie>=50?`Tu índice IE de ${ie} muestra una capacidad emocional sólida con espacio de desarrollo. Trabajar en Resiliencia o Empatía puede tener un impacto directo.`:`Tu índice IE de ${ie} señala una oportunidad de desarrollo emocional importante. No define tu valor como persona, sino el área donde tu crecimiento puede ser más significativo.`;
  document.getElementById('iedesc').textContent=d;
  document.getElementById('iedev').textContent=IE_DEV[ie>=75?0:ie>=50?1:2];
}

function bldIM(im){
  const top=im[0],bot=im[im.length-1];
  document.getElementById('imblock').innerHTML=`
    <div class="im-row-card"><div class="im-lbl hi">◆ Predominante (${top.score}/100)</div><div class="im-name">${top.name}</div><div class="im-text">${top.hi}</div></div>
    <div class="im-row-card"><div class="im-lbl lo">△ Menos desarrollada (${bot.score}/100)</div><div class="im-name">${bot.name}</div><div class="im-text">${bot.lo}</div></div>`;
}

function bldCompat(arch){
  const g=document.getElementById('cgrid');g.innerHTML='';
  arch.compat.forEach(c=>{
    const a=ARCH.find(x=>x.key===c.k);if(!a)return;
    const nm=user.sex==='F'?a.nameF:a.nameM;
    const card=document.createElement('div');card.className='ccard';
    card.innerHTML=`<div class="chdr"><div class="cicon-box" style="border-color:var(--border)"><div style="color:var(--acc2)">${ICONS[a.iconKey]||''}</div></div><span class="cname">${nm}</span></div><span class="clvl ${c.l}">${c.l==='h'?'◆ Alta afinidad':'◈ Afinidad media'}</span><div class="creason">${c.r}</div>`;
    g.appendChild(card);
  });
}

function bldRec(arch){
  const pairs=[
    ['ggrid', arch.games, 'Videojuego recomendado'],
    ['agrid', arch.anime,  'Anime recomendado'],
    ['bgrid', arch.books,  'Libro recomendado'],
  ];
  pairs.forEach(([id,recs,type])=>{
    const g=document.getElementById(id);if(!g)return;g.innerHTML='';
    (recs||[]).forEach(r=>{
      const c=document.createElement('div');c.className='rcard';
      c.innerHTML=`<div class="rtype">${type}</div><div class="rtitle">${r.t}</div><div class="rwhy">${r.w}</div>`;
      g.appendChild(c);
    });
  });
}

function bldAdv(arch,nm){
