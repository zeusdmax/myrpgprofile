let lyraHistory = [];
let lyraApiKey = "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";
let lyraProfile = {};
let lyraTyping = false;

function getAgeGroup(age) {
  if (age < 13) return 'child';
  if (age < 18) return 'teen';
  return 'adult';
}

function buildSystemPrompt(profile) {
  const ag = getAgeGroup(profile.age);
  const ageTone = ag === 'child'
    ? 'Hablas con un niño de ' + profile.age + ' años. Usa lenguaje muy simple, oraciones cortas, analogías con juegos y cuentos, mucho entusiasmo y emojis ocasionales. Nunca temas validar, siempre celebra. Evita conceptos abstractos complejos.'
    : ag === 'teen'
    ? 'Hablas con un adolescente de ' + profile.age + ' años. Usa lenguaje directo y auténtico, sin condescendencia. Respeta su identidad, valida sus emociones, usa referencias culturales actuales con moderación. Puedes abordar temas de identidad, relaciones y futuro con apertura.'
    : 'Hablas con un adulto de ' + profile.age + ' años. Puedes usar conceptos psicológicos con naturalidad. Sé cálido pero directo, evita el paternalismo. Puedes explorar temas profundos de propósito, relaciones, crecimiento personal.';

  const sexPolicy = profile.age >= 18
    ? 'Si el usuario pregunta sobre educación sexual, puedes responder con información científica, neutral y responsable. Si es un tema delicado, abórdalo con cuidado y sin juicio.'
    : 'NUNCA abordes contenido sexual o erótico. Si el usuario pregunta, redirige con calidez hacia temas apropiados para su edad.';

  return `Eres Lyra, una maga sabia y tierna que vive en la taberna del Gremio del Conocimiento. Hablas siempre con un tono cálido, levemente medieval-fantástico, como si conversaras junto al fuego en una taberna acogedora. Eres experta en psicología, narración terapéutica y desarrollo humano, pero nunca lo haces evidente: tu ciencia se nota en la profundidad, no en el lenguaje técnico.

Tu misión: co-construir con el viajero una nueva narrativa de sí mismo. Validas, preguntas, expandes, nunca juzgas. Eres como una guía de D&D que también sabe de psicología positiva, teoría narrativa y desarrollo del carácter.

PERFIL DEL VIAJERO:
- Nombre: ${profile.name}
- Edad: ${profile.age} años
- Clase: ${profile.archName}
- Atributos (0-100): ${Object.entries(profile.scores).map(([k,v])=>k+': '+v).join(', ')}
- Índice IE: ${profile.ie}
- Inteligencia predominante: ${profile.imTop}
- Inteligencia menos desarrollada: ${profile.imBot}

REGLAS DE TONO Y EDAD:
${ageTone}

CONTENIDO:
- Puedes hablar sobre: resultados del perfil, crecimiento personal, recomendaciones de libros/juegos/anime/deportes/actividades, narrativas personales, cuentos, reflexiones de vida, metas, relaciones, emociones.
- Siempre contextualiza según la edad y clase del viajero.
- ${sexPolicy}
- NUNCA generes contenido violento, discriminatorio, ni dañino.
- Si detectas señales de angustia real o crisis, sal del personaje brevemente y sugiere con cuidado buscar apoyo profesional o de confianza.

ESTILO:
- Llama al usuario "viajero" o por su nombre ocasionalmente.
- Usa metáforas de RPG con moderación: pergaminos, hechizos, gremios, tabernas, misiones.
- Respuestas entre 60 y 200 palabras salvo que pidan algo extenso (cuento, reflexión larga).
- Termina a veces con una pregunta suave que invite a seguir explorando.`;
}

function buildLyraUI(profile) {
  lyraProfile = profile;
  const ageGroup = getAgeGroup(profile.age);
  const greetings = {
    child: `¡Bienvenido, pequeño aventurero ${profile.name}! ✨ Soy Lyra, la maga de esta taberna. Vi tus resultados y... ¡son increíbles! Eres ${profile.archName}. ¿Sabes lo que eso significa? ¡Que tienes poderes muy especiales! ¿Me cuentas qué parte te gustó más?`,
    teen: `Hola, ${profile.name}. Soy Lyra — llevo años estudiando los pergaminos del Gremio, y pocas veces veo un perfil tan interesante como el tuyo. ${profile.archName}... eso dice mucho de ti. ¿Qué fue lo que más te sorprendió de tus resultados?`,
    adult: `Bien hallado, ${profile.name}. Me llamo Lyra, y esta taberna lleva siglos recibiendo viajeros que buscan entenderse mejor. Tu clase — ${profile.archName} — no es común. Hay mucho que explorar aquí. ¿Por dónde te gustaría empezar?`
  };

  const chips = [
    '¿Qué significa mi clase?',
    'Cuéntame sobre mis atributos',
    'Escribe un cuento con mi personaje',
    '¿Cómo puedo mejorar?',
    'Recomiéndame algo para mi edad',
    '¿Cuál sería mi vida ideal?',
  ];

  const section = document.getElementById('lyra-section');
  section.innerHTML = `
    <div class="lyra-wrap">
      <div class="lyra-head">
        <div class="lyra-figure">${LYRA_SVG}</div>
        <div style="flex:1;padding-bottom:.75rem">
          <div class="lyra-name">Lyra · Maga del Gremio del Conocimiento</div>
          <div class="lyra-bubble" id="lyra-greeting">${greetings[ageGroup]}</div>
        </div>
      </div>
      
      <div class="lyra-chips" id="lyra-chips">
        ${chips.map(c=>`<span class="lyra-chip" onclick="sendChip('${c}')">${c}</span>`).join('')}
      </div>
      <div class="lyra-messages" id="lyra-msgs"></div>
      <div class="lyra-input-row">
        <textarea class="lyra-input" id="lyra-input" placeholder="Escribe tu pregunta al gremio..." rows="1"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg()}"
          oninput="this.style.height='42px';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
        <button class="lyra-send" id="lyra-btn" onclick="sendMsg()" title="Enviar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13M22 2L15 22L11 13L2 9L22 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>`;

  lyraHistory = [];
}

function sendChip(text) {
  document.getElementById('lyra-input').value = text;
  sendMsg();
}

async function sendMsg() {
  if (lyraTyping) return;
  const input = document.getElementById('lyra-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = ''; input.style.height = '42px';

  // Remove chips after first real message
  const chips = document.getElementById('lyra-chips');
  if (chips) chips.style.display = 'none';

  // Add user message
  appendMsg(text, 'user');
  lyraHistory.push({ role:'user', content: text });

  // Show typing
  lyraTyping = true;
  document.getElementById('lyra-btn').disabled = true;
  const typingId = 'typing_' + Date.now();
  appendTyping(typingId);

  try {
    const res = await fetch('/api/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        systemPrompt: buildSystemPrompt(lyraProfile),
        messages: lyraHistory
      })
    });
    const data = await res.json();
    const reply = data.reply || 'Los pergaminos del gremio están ocupados en este momento. Inténtalo de nuevo, viajero.';
    removeTyping(typingId);
    appendMsg(reply, 'lyra');
    lyraHistory.push({ role:'assistant', content: reply });
  } catch(e) {
    removeTyping(typingId);
    appendMsg('Los vientos mágicos interfieren con mi bola de cristal. Inténtalo de nuevo.', 'lyra');
  }

  lyraTyping = false;
  document.getElementById('lyra-btn').disabled = false;
  document.getElementById('lyra-input').focus();
}

function appendMsg(text, who) {
  const msgs = document.getElementById('lyra-msgs');
  const d = document.createElement('div');
  d.className = 'msg ' + who;
  const avatarContent = who === 'lyra'
    ? `<div class="msg-avatar lyra-av">✦</div>`
    : `<div class="msg-avatar user-av">${(lyraProfile.name||'?')[0].toUpperCase()}</div>`;
  d.innerHTML = avatarContent + `<div class="msg-body">${text.replace(/\n/g,'<br>')}</div>`;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
}

function appendTyping(id) {
  const msgs = document.getElementById('lyra-msgs');
  const d = document.createElement('div');
  d.className = 'msg lyra'; d.id = id;
  d.innerHTML = `<div class="msg-avatar lyra-av">✦</div><div class="msg-body typing"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>`;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping(id) {
  const el = document.getElementById(id);
  if (el) el.remove();
}

</script>
