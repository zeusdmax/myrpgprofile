{
  "version": 2,
  "functions": {
    "api/chat.js": { "runtime": "nodejs20.x" },
    "api/guardar.js": { "runtime": "nodejs20.x" }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/guardar", "dest": "/api/guardar.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
