const ARCH=[
  {key:'arquitecto',css:'s-arquitecto',iconKey:'estructura',
   nameM:'El Arquitecto del Destino',nameF:'La Arquitecta del Destino',
   sub:'Maestro del tablero · Clase de control',dims:['voluntad','vision','estructura'],
   desc:'Piensas en sistemas donde otros ven eventos aislados. Tu mente construye mapas mientras los demás aún buscan la brújula. Eres la persona que llega con el plan cuando el caos toca la puerta.',
   str:['Pensamiento estratégico','Autodisciplina extrema','Visión de largo plazo'],wk:['Rigidez ante lo imprevisto','Puede subestimar lo emocional'],
   motto:'{{n}}, estás entre el grupo más selecto de Arquitectos. Tu combinación de Voluntad y Visión te da un poder que pocas clases poseen: la capacidad de convertir ideas en realidades. Ese potencial que llevas todavía no lo has explotado del todo.',
   advice:['Usa tu capacidad de planificación para trazar metas a 3 y 12 meses, no solo en lo inmediato.','Practica la iteración rápida: no siempre el plan perfecto es mejor que uno bueno ejecutado ya.','Busca aliados con Empatía alta; ellos ven lo que tú, enfocado en el tablero, puedes pasar por alto.'],
   games:[{t:'Divinity: Original Sin 2',w:'RPG táctico donde cada decisión tiene consecuencias en cadena. El sistema de combate por turnos premia exactamente la planificación profunda de esta clase.'},{t:'Civilization VI',w:'Gestión de imperios y planificación a largo plazo. Diseñado para mentes que disfrutan de la complejidad controlada y los sistemas interconectados.'},{t:'Disco Elysium',w:'RPG de investigación donde tu estilo de pensamiento moldea la narrativa. Valora el razonamiento deductivo y decisiones con consecuencias reales.'}],
   anime:[{t:'Code Geass',w:'Lelouch es el arquetipo del Arquitecto en su forma más pura: movimientos a largo plazo, sacrificio calculado y una mente que siempre va varios pasos adelante.'},{t:'Legend of the Galactic Heroes',w:'Política, guerra y filosofía en escala épica. Una obra que solo los pensadores de largo plazo saben apreciar.'},{t:"Steins;Gate",w:'Una mente que no para de buscar patrones y conexiones, incluso cuando el costo personal es enorme. El Arquitecto se verá reflejado en Okabe.'}],
   compat:[{k:'paladin',l:'h',r:'El Paladín ejecuta con fidelidad lo que el Arquitecto diseña.'},{k:'portador_fuego',l:'h',r:'El Portador del Fuego aporta la energía que al Arquitecto le puede faltar.'},{k:'navegante',l:'m',r:'Aporta perspectivas que el Arquitecto nunca consideraría.'},{k:'equilibrio',l:'m',r:'El Portador del Equilibrio suaviza los bordes duros del Arquitecto.'}],
   books:[{t:'El Arte de la Guerra — Sun Tzu',w:'El manual que todo Arquitecto tiene incorporado sin saberlo. Sistemas, anticipación y control del tablero con la mínima fuerza.'},{t:'Pensar rápido, pensar despacio — Daniel Kahneman',w:'Dos sistemas de pensamiento que el Arquitecto reconoce en sí mismo. Imprescindible para entender por qué los planes fallan donde no debían.'},{t:'El jugador de ajedrez — Stefan Zweig',w:'Un relato sobre la mente que se vuelve prisión y arma al mismo tiempo. Brevísimo, devastador y exactamente en el idioma de esta clase.'},{t:'Sapiens — Yuval Noah Harari',w:'Visión de largo plazo sobre sistemas humanos a escala civilizatoria. El Arquitecto encontrará aquí el tablero más grande que existe.'},{t:'Los pilares de la tierra — Ken Follett',w:'Construir algo monumental con recursos limitados, en un mundo que no coopera. La epopeya del Arquitecto hecha novela.'}]},
  {key:'portador_fuego',css:'s-portador-fuego',iconKey:'accion',
   nameM:'El Portador del Fuego',nameF:'La Portadora del Fuego',
   sub:'Motor del cambio · Clase de carisma',dims:['accion','influencia','vision'],
   desc:'Donde tú entras, las cosas se mueven. Tienes el raro don de ver el potencial en las personas y en las situaciones, y la energía para encenderlo. Los grupos estáticos encuentran su rumbo cuando apareces.',
   str:['Movilización de equipos','Carisma natural','Adaptabilidad espontánea'],wk:['Puede sacrificar profundidad por velocidad','Dificultad con la rutina'],
   motto:'{{n}}, eres de ese porcentaje de Portadores del Fuego que además tiene Visión desarrollada. Eso te hace más que un activador: eres quien puede mover a otros hacia algo que realmente vale la pena.',
   advice:['Aprovecha tu energía social para construir redes reales, no solo conexiones superficiales.','Pon por escrito tus ideas antes de compartirlas: el papel frena el impulso y da estructura al mensaje.','Busca un Forjador o Arquitecto en tu círculo; ellos llevan a término lo que tú inicias.'],
   games:[{t:'Hades',w:'Frenético, caótico y brillante. Cada run es diferente, exactamente lo que un Portador del Fuego necesita. Recompensa la acción sobre la parálisis.'},{t:'Mass Effect (saga)',w:'Tu capacidad de influir en personajes y facciones determina el resultado del universo entero. Esta clase en su máxima expresión.'},{t:'Overwatch 2',w:'Liderar y coordinar bajo presión es la diferencia entre ganar y perder. Los Portadores del Fuego brillan en este caos controlado.'}],
   anime:[{t:'Gurren Lagann',w:'Simon y Kamina son el Portador del Fuego en estado puro: acción sobre análisis, energía que contagia, creer en uno mismo hasta lo imposible.'},{t:'Haikyuu!!',w:'Sobre liderazgo espontáneo y la energía que transforma grupos ordinarios en algo extraordinario. Perfecto para esta clase.'},{t:'My Hero Academia',w:'El crecimiento de un protagonista que aprende a usar su poder para levantar a otros refleja el arco natural del Portador del Fuego.'}],
   compat:[{k:'forjador',l:'h',r:'El Forjador termina lo que el Portador del Fuego inicia. El ancla de ejecución que siempre necesita.'},{k:'arquitecto',l:'h',r:'El Arquitecto le da dirección al impulso. Juntos son difíciles de detener.'},{k:'equilibrio',l:'m',r:'Gestiona el impacto emocional que puede dejarse involuntariamente en el camino.'},{k:'paladin',l:'m',r:'El Paladín sostiene la estabilidad mientras el Portador del Fuego genera el cambio.'}],
   books:[{t:'El poder del ahora — Eckhart Tolle',w:'Para el Portador del Fuego que corre tan rápido que se olvida de habitar el presente. Equilibra la energía sin apagarla.'},{t:'Blink — Malcolm Gladwell',w:'Sobre la intuición experta y las decisiones que se toman en segundos. El libro que valida el instinto del Portador del Fuego.'},{t:'La guerra del arte — Steven Pressfield',w:'Para cuando el fuego baja. Sobre la resistencia creativa y cómo vencerla. Directo, breve y poderoso.'},{t:'Empieza con el porqué — Simon Sinek',w:'Los grandes líderes inspiran acción desde un propósito central. El manual de influencia de esta clase.'},{t:'El Alquimista — Paulo Coelho',w:'Sencillo en la forma, profundo en el mensaje: el mundo conspira a favor de quien sabe lo que quiere y actúa. El alma del Portador del Fuego.'}]},
  {key:'paladin',css:'s-paladin',iconKey:'resiliencia',
   nameM:'El Paladín',nameF:'La Paladina',
   sub:'Pilar del grupo · Clase de resistencia',dims:['resiliencia','estructura','empatia'],
   desc:'Las personas sienten que contigo están a salvo. No porque elimines el peligro, sino porque tu estabilidad les da suelo firme bajo los pies. Eres el tipo de persona que recuerdan cuando el mundo tambalea.',
   str:['Confiabilidad extrema','Estabilidad emocional','Cohesión grupal'],wk:['Puede resistirse al cambio necesario','Tendencia a evitar conflictos'],
   motto:'{{n}}, los Paladines con Empatía alta son los más raros y valiosos de cualquier grupo. Puedes sentir lo que otros sienten y mantenerte firme mientras lo haces. Eso es lo que los líderes más efectivos de la historia tuvieron en común contigo.',
   advice:['Tu tendencia a sostener puede convertirse en carga si no aprendes a decir "esto no es mi responsabilidad".','Practica el conflicto constructivo: la paz real no es ausencia de tensión, sino resolución honesta.','Busca un Portador del Fuego o Navegante; ellos te recordarán que el cambio también puede ser bueno.'],
   games:[{t:"Dragon Age: Origins",w:'RPG donde la lealtad, las relaciones y el sacrificio definen el resultado. El Paladín reconocerá cada dilema moral y encontrará profundidad real.'},{t:'Final Fantasy XIV',w:'MMO que valora enormemente el trabajo en equipo. Los Paladines suelen ser los mejores healers y tanks del servidor.'},{t:'Stardew Valley',w:'Construir, cuidar y sostener una comunidad. Exactamente la energía de esta clase. Simple en superficie, profundo en satisfacción.'}],
   anime:[{t:'Violet Evergarden',w:'Sobre aprender a reconocer y comunicar emociones profundas. El viaje de Violet refleja la vida interior silenciosa de muchos Paladines.'},{t:'Fullmetal Alchemist: Brotherhood',w:'Sacrificio, responsabilidad y proteger a quienes amas. El alma de esta clase está en la relación entre los hermanos Elric.'},{t:'A Silent Voice',w:'Sobre reparar relaciones rotas y el peso de la empatía genuina. Un Paladín lo entenderá desde el primer fotograma.'}],
   compat:[{k:'portador_fuego',l:'h',r:'El Portador del Fuego mueve; el Paladín sostiene. Son el movimiento y el ancla perfectos.'},{k:'arquitecto',l:'h',r:'El Arquitecto da el mapa; el Paladín protege el camino. Combinación clásica y poderosa.'},{k:'equilibrio',l:'m',r:'Alta afinidad emocional, aunque pueden crear una burbuja demasiado cómoda.'},{k:'forjador',l:'m',r:'Comparten el amor por la constancia. Juntos construyen cosas que duran.'}],
   books:[{t:'El hombre en busca de sentido — Viktor Frankl',w:'Resiliencia, propósito y la capacidad de sostener la humanidad en las circunstancias más extremas. El libro fundamental para esta clase.'},{t:'Los cuatro acuerdos — Miguel Ruiz',w:'Principios para vivir con integridad, sin cargar el peso de los demás. El Paladín aprenderá a cuidar sin agotarse.'},{t:'La ciudad y los perros — Mario Vargas Llosa',w:'Sobre lealtad, códigos de honor y el costo de sostener a un grupo. El Paladín reconocerá cada dilema moral.'},{t:'Mujeres que corren con los lobos — Clarissa Pinkola Estés',w:'Para los Paladines que se han olvidado de sí mismos en el acto de proteger a otros. Un libro de recuperación de la propia voz.'},{t:'Cien años de soledad — Gabriel García Márquez',w:'Sobre lo que se hereda, lo que se construye y lo que se desmorona. El Paladín es el tejido que evita que todo colapse.'}]},
  {key:'profeta',css:'s-profeta',iconKey:'vision',
   nameM:'El Profeta',nameF:'La Profeta',
   sub:'Arquitecto del futuro · Clase creativa',dims:['vision','accion','influencia'],
   desc:'Ves mundos donde otros ven obstáculos. Tienes la extraña capacidad de adelantarte a tu tiempo, de generar ideas que la gente no entiende hoy pero cita mañana. Tu mayor don es también tu mayor desafío: vivir en el futuro.',
   str:['Creatividad disruptiva','Visión de posibilidades','Capacidad inspiradora'],wk:['Puede desconectarse de la ejecución','Impaciencia con los detalles'],
   motto:"{{n}}, los Profetas con alta Acción son los que realmente cambian las cosas. No solo ves el futuro: lo empujas. Ese potencial creativo que tienes todavía no ha encontrado su máxima expresión. Cuando lo haga, va a ser difícil ignorarte.",
   advice:['Encuentra un sistema de captura de ideas: tu mente genera más de lo que puedes retener. Un diario, una app, lo que sea.','Aprende a "vender" tus ideas en el lenguaje de quien las ejecuta: detalle, plazos, recursos concretos.','El Forjador y el Arquitecto son tus aliados naturales; ellos construyen lo que tú imaginas.'],
   games:[{t:"No Man's Sky",w:'Un universo infinito de exploración y creación. Los Profetas encuentran en este juego un espejo de su mente: siempre hay algo nuevo en el horizonte.'},{t:'Outer Wilds',w:'Investigación, exploración y descubrimiento puro. Diseñado para mentes que disfrutan de conectar pistas dispersas en un sistema coherente.'},{t:"Baldur's Gate 3",w:'Un RPG que recompensa la creatividad en la resolución de problemas. Casi todo tiene múltiples soluciones, exactamente lo que un Profeta necesita.'}],
   anime:[{t:'Neon Genesis Evangelion',w:'Para los Profetas que no le temen a la profundidad psicológica. Una obra que redefine lo que el anime puede hacer como medio expresivo.'},{t:'Vinland Saga',w:'Un visionario que construye su ideal en un mundo que no está listo para él. La tensión entre la visión y la realidad es el corazón de esta historia.'},{t:'Carole & Tuesday',w:'Sobre crear algo genuino en un mundo donde todo está automatizado. El Profeta reconocerá esa lucha inmediatamente.'}],
   compat:[{k:'forjador',l:'h',r:'El Forjador toma la visión y la convierte en realidad tangible. La mano derecha que todo Profeta necesita.'},{k:'arquitecto',l:'h',r:'El Arquitecto organiza el caos creativo del Profeta y lo convierte en plan ejecutable.'},{k:'navegante',l:'m',r:'Alta afinidad creativa, pero ambos pueden perderse juntos sin un ancla.'},{k:'paladin',l:'m',r:'El Paladín ancla al Profeta al presente cuando este se pierde en el futuro.'}],
   books:[{t:'El origen de las especies — Charles Darwin',w:'El libro que cambió todo con una idea que tardó décadas en ser aceptada. El Profeta entenderá la soledad de ver antes que otros.'},{t:'1984 — George Orwell',w:'Una visión del futuro que llegó como advertencia. El Profeta lo leerá como diagnóstico, no como ficción.'},{t:'La imaginación creadora — Gaston Bachelard',w:'Filosofía de la imagen y la ensoñación como formas legítimas de conocimiento. El Profeta encontrará aquí validación teórica de su forma de pensar.'},{t:'Crónica de una muerte anunciada — García Márquez',w:'Sobre el futuro que todos ven pero nadie evita. La tragedia del Profeta en formato literario perfecto.'},{t:'El Señor de los Anillos — J.R.R. Tolkien',w:'La construcción de un mundo completo desde cero. El Profeta que aún no ha leído esto tiene pendiente el libro que más lo va a marcar.'}]},
  {key:'forjador',css:'s-forjador',iconKey:'voluntad',
   nameM:'El Forjador de Estrellas',nameF:'La Forjadora de Estrellas',
   sub:'Maestro del oficio · Clase de precisión',dims:['voluntad','estructura','resiliencia'],
   desc:'Lo que sale de tus manos, dura. Tienes una relación especial con la calidad que otros no entienden hasta que ven el resultado. Tu paciencia y tu estándar alto son dos caras de la misma moneda.',
   str:['Calidad de ejecución','Persistencia bajo presión','Resistencia al estrés'],wk:['Puede tornarse perfeccionista rígido','Dificultad para delegar'],
   motto:'{{n}}, los Forjadores de Estrellas con alta Resiliencia son los que terminan en pie cuando todos los demás ya cayeron. Tu combinación de precisión y resistencia es lo que los equipos más sólidos siempre están buscando.',
   advice:['Establece un criterio explícito de "suficientemente bueno" para cada tarea: no todo requiere el mismo estándar.','Practica el arte de delegar lo que no es crítico. Tu energía es un recurso finito y valioso.','Busca Profetas y Portadores del Fuego; ellos te recuerdan por qué el trabajo vale la pena.'],
   games:[{t:'Dark Souls (saga)',w:'El juego definitivo de la persistencia. Diseñado para quienes se niegan a rendirse y encuentran satisfacción en dominar algo difícil a fuerza de repetición.'},{t:'Factorio',w:'Automatización, sistemas y optimización. Recompensa la paciencia, la atención al detalle y el pensamiento sistemático en su forma más pura.'},{t:'Monster Hunter: World',w:'Aprender patrones, perfeccionar técnica y mejorar constantemente. Los Forjadores suelen ser los hunters más efectivos y constantes.'}],
   anime:[{t:'Mushishi',w:'Sobre la maestría silenciosa y el trabajo que se hace bien porque es lo correcto, sin importar el reconocimiento. Esta clase en su forma más pura.'},{t:'Mob Psycho 100',w:'La historia de un personaje que aprende que la verdadera fortaleza es el carácter construido a través del esfuerzo sostenido y honesto.'},{t:'Vinland Saga (segunda parte)',w:'El arco de Thorfinn construyendo algo nuevo desde cero, solo constancia y propósito. Un reflejo del Forjador en su etapa más madura.'}],
   compat:[{k:'profeta',l:'h',r:'El Profeta imagina; el Forjador construye. La combinación más productiva entre dos clases.'},{k:'portador_fuego',l:'h',r:'El Portador del Fuego genera el impulso; el Forjador lo convierte en resultado concreto.'},{k:'paladin',l:'m',r:'Comparten el amor por la constancia y el trabajo bien hecho.'},{k:'arquitecto',l:'m',r:'El Arquitecto da el marco; el Forjador llena los detalles. Funciona muy bien con respeto mutuo.'}],
   books:[{t:'El maestro y Margarita — Bulgakov',w:'Sobre el artesano que no compromete su obra aunque el mundo entero lo persiga. Extraño, profundo y libre.'},{t:'Musashi — Eiji Yoshikawa',w:'La vida de un guerrero que convierte cada derrota en precisión. El manual de vida del Forjador de Estrellas.'},{t:'Deep Work — Cal Newport',w:'Cómo proteger el tiempo de trabajo profundo en un mundo de distracciones. El Forjador ya lo hace; este libro le da el lenguaje para defenderlo.'},{t:'El Quijote — Miguel de Cervantes',w:'Sobre la persistencia en la visión propia cuando el mundo la llama locura. El Forjador de Estrellas lo entenderá de otra forma que cualquier otro arquetipo.'},{t:'El monje que vendió su Ferrari — Robin Sharma',w:'Excelencia, disciplina y el rediseño consciente de los hábitos. La guía de desarrollo personal más afín a esta clase.'}]},
  {key:'equilibrio',css:'s-equilibrio',iconKey:'empatia',
   nameM:'El Portador del Equilibrio',nameF:'La Portadora del Equilibrio',
   sub:'Puente entre mundos · Clase de armonía',dims:['empatia','resiliencia','voluntad'],
   desc:'Eres el que transforma grupos en comunidades. Sientes lo que otros sienten antes de que lo digan, y tienes la fortaleza para sostener esa carga sin quebrarte. Las tensiones que paralizan a otros, tú las disuelves.',
