<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>MyRPGProfile</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#050b18;--surface:rgba(6,12,26,0.90);--surface2:rgba(10,18,36,0.86);
  --gold:#e8c84a;--gold2:#f5dc7a;--gold3:#fff4b8;--silver:#c0c8d8;
  --text:#f2f6ff;--text2:#c4d4e4;--text3:#8ca0b4;
  --border:rgba(232,200,74,0.22);--border2:rgba(232,200,74,0.10);
  --acc:#e8c84a;--acc2:#f5dc7a;--glow:rgba(232,200,74,0.18);
}
body.s-arquitecto{--acc:#5aadff;--acc2:#90ccff;--glow:rgba(90,173,255,0.18)}
body.s-portador-fuego{--acc:#ff8a3a;--acc2:#ffb87a;--glow:rgba(255,138,58,0.18)}
body.s-paladin{--acc:#3adfa8;--acc2:#7af5cc;--glow:rgba(58,223,168,0.18)}
body.s-profeta{--acc:#c070ff;--acc2:#daa8ff;--glow:rgba(192,112,255,0.18)}
body.s-forjador{--acc:#f5dc7a;--acc2:#fff4b8;--glow:rgba(245,220,122,0.18)}
body.s-equilibrio{--acc:#ff70a0;--acc2:#ffb0c8;--glow:rgba(255,112,160,0.18)}
body.s-navegante{--acc:#40e0f0;--acc2:#90f4fc;--glow:rgba(64,224,240,0.18)}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Crimson Pro',Georgia,serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* ── WORLD BACKGROUND ── */
#world-canvas{position:fixed;inset:0;z-index:0;width:100%;height:100%}
#world-overlay{position:fixed;inset:0;z-index:1;background:linear-gradient(180deg,rgba(2,5,12,0.55) 0%,rgba(3,7,16,0.60) 60%,rgba(3,8,18,0.65) 100%);pointer-events:none}
#app{position:relative;z-index:2}

/* ── SCREEN TRANSITIONS ── */
.screen{display:none;min-height:100vh;opacity:0}
.screen.active{display:flex;flex-direction:column;animation:pageIn .45s cubic-bezier(.25,.46,.45,.94) forwards}
@keyframes pageIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* ── SHARED ── */
.glass{background:var(--surface);border:1px solid var(--border);border-radius:14px;position:relative;overflow:hidden;backdrop-filter:blur(8px)}
.glass::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.divider-gold{width:120px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:1.25rem auto}

/* Buttons */
.btn-p{background:linear-gradient(135deg,#a07820,var(--gold2));color:#050b18;border:none;border-radius:9px;padding:.96rem 1.6rem;font-family:'Cinzel',serif;font-size:.97rem;font-weight:700;cursor:pointer;letter-spacing:.08em;transition:all .22s;box-shadow:0 4px 22px rgba(232,200,74,.28),0 1px 0 rgba(255,255,255,.08) inset}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(232,200,74,.42);filter:brightness(1.08)}
.btn-p:active{transform:translateY(0)}
.btn-s{background:rgba(10,18,36,.6);border:1px solid var(--border);color:var(--text2);border-radius:9px;padding:.90rem 1.3rem;font-family:'Crimson Pro',serif;font-size:1.0rem;cursor:pointer;transition:all .22s;backdrop-filter:blur(4px)}
.btn-s:hover{border-color:var(--gold);color:var(--gold2);background:rgba(20,30,60,.7);transform:translateY(-1px)}

/* Section titles */
.sep{font-family:'Cinzel',serif;font-size:.93rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;margin:2.2rem 0 1rem;display:flex;align-items:center;gap:.8rem;color:var(--acc);text-shadow:0 0 14px var(--glow)}
.sep::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent)}

/* ── WELCOME ── */
#welcome{align-items:center;justify-content:center;padding:2rem;text-align:center}
.logo-pre{font-family:'JetBrains Mono',monospace;font-size:.75rem;letter-spacing:.32em;color:var(--gold2);opacity:.85;text-transform:uppercase;margin-bottom:.6rem;text-shadow:0 0 12px rgba(232,200,74,.4)}
.logo-main{font-family:'Cinzel',serif;font-size:clamp(2.4rem,8vw,4.4rem);font-weight:900;letter-spacing:.06em;line-height:1;background:linear-gradient(90deg,#c9a030 0%,var(--gold2) 20%,var(--gold3) 42%,var(--gold2) 58%,#c9a030 78%,var(--gold2) 100%);background-size:250% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;-webkit-text-fill-color:var(--gold2);color:var(--gold2);animation:logoGlow 3s ease-in-out infinite}
@keyframes shimmer{to{background-position:250% center}}
@keyframes logoGlow{0%,100%{text-shadow:0 0 18px rgba(232,200,74,.4),0 0 40px rgba(232,200,74,.15)}50%{text-shadow:0 0 32px rgba(232,200,74,.85),0 0 70px rgba(245,220,122,.4),0 0 110px rgba(232,200,74,.2)}}
.logo-main span{color:var(--silver)}
.logo-sub{font-family:'Crimson Pro',serif;font-style:italic;font-size:.98rem;color:var(--text3);letter-spacing:.16em;text-transform:uppercase;margin-top:.5rem}
.pitch-text{max-width:460px;margin:1.5rem auto;font-size:1.09rem;color:var(--text2);line-height:1.9;font-style:italic}
.pitch-list{display:flex;flex-direction:column;gap:.55rem;max-width:380px;margin:0 auto 2rem;text-align:left}
.pi{display:flex;align-items:flex-start;gap:.8rem;font-size:.98rem;color:var(--text2);line-height:1.6}
.pi-icon{color:var(--gold2);flex-shrink:0;margin-top:.1rem;font-size:.93rem;text-shadow:0 0 8px rgba(232,200,74,.5)}
.rcard{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:2.1rem;max-width:440px;width:100%;position:relative;overflow:hidden;backdrop-filter:blur(12px)}
.rcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.rcard h2{font-family:'Cinzel',serif;font-size:1.09rem;color:var(--gold2);margin-bottom:1.5rem;letter-spacing:.05em;text-shadow:0 0 10px rgba(232,200,74,.3)}
.row2{display:flex;gap:.75rem}
.fg{margin-bottom:.9rem;flex:1}
.fg label{display:block;font-family:'JetBrains Mono',monospace;font-size:.74rem;letter-spacing:.13em;text-transform:uppercase;color:var(--text2);margin-bottom:.42rem;text-shadow:0 0 8px rgba(196,212,228,.2)}
.fg input,.fg select{width:100%;background:rgba(8,16,36,.85);border:1px solid var(--border2);border-radius:7px;padding:.94rem .9rem;color:var(--text);font-family:'Crimson Pro',serif;font-size:1rem;outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none}
.fg input:focus,.fg select:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(232,200,74,.12)}
.fg input::placeholder{color:var(--text3);font-style:italic}
.fg select option{background:#08101e;color:var(--text)}
.sex-note{font-size:.76rem;color:var(--text2);font-style:italic;margin-bottom:.9rem;line-height:1.65}
.err-box{padding:.90rem .9rem;background:rgba(255,80,80,.09);border:1px solid rgba(255,80,80,.25);border-radius:7px;color:#ffaaaa;font-size:1.01rem;margin-bottom:.9rem;display:none}

/* ── INSTRUCTIONS ── */
#instructions{align-items:center;justify-content:center;padding:2rem}
.icard{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:2.6rem;max-width:580px;width:100%;position:relative;overflow:hidden;backdrop-filter:blur(12px)}
.icard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.icard-title{font-family:'Cinzel',serif;font-size:1.4rem;font-weight:700;color:var(--gold2);margin-bottom:.4rem;letter-spacing:.04em;text-shadow:0 0 14px rgba(232,200,74,.4)}
.icard-sub{font-family:'Cinzel',serif;font-size:.98rem;color:var(--text2);letter-spacing:.1em;margin-bottom:1.6rem}
.epic-text{font-size:1.06rem;color:var(--text2);line-height:1.85;font-style:italic;margin-bottom:1.25rem}
.epic-text strong{color:var(--gold2);font-style:normal;font-weight:500}
.chips{display:flex;flex-wrap:wrap;gap:.5rem;margin:1rem 0}
.chip{background:rgba(12,22,44,.85);border:1px solid var(--border);border-radius:20px;padding:.28rem .96rem;font-family:'JetBrains Mono',monospace;font-size:1.0rem;color:var(--gold2);letter-spacing:.05em;white-space:nowrap}
.scale-box{background:rgba(10,20,40,.8);border:1px solid var(--border2);border-radius:9px;padding:1rem 1.3rem;margin:1.25rem 0;font-size:1.0rem;color:var(--text2);line-height:1.8}
.scale-box strong{color:var(--gold2)}
.disclaimer{font-size:.90rem;color:var(--text2);line-height:1.7;margin-bottom:1.6rem;font-style:italic;opacity:.9}
.ibtns{display:flex;gap:.8rem}

/* ── QUESTIONNAIRE ── */
#questionnaire{padding:0}
.qhdr{background:rgba(4,8,18,.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--border2);padding:.96rem 1.6rem;display:flex;align-items:center;gap:1.5rem;position:sticky;top:0;z-index:30}
.qlogo{font-family:'Cinzel',serif;font-size:1rem;font-weight:700;white-space:nowrap;color:var(--gold2);text-shadow:0 0 14px rgba(232,200,74,.5);animation:logoGlow 3s ease-in-out infinite}
.pwrap{flex:1}
.pmeta{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:.90rem;color:var(--text2);margin-bottom:.38rem;letter-spacing:.07em}
.ptrack{height:6px;background:rgba(10,18,36,.9);border-radius:3px;overflow:visible;position:relative;box-shadow:inset 0 1px 3px rgba(0,0,0,.4)}
.pfill{height:100%;background:linear-gradient(90deg,#a07820,var(--gold2),var(--gold3));border-radius:3px;transition:width .55s cubic-bezier(.4,0,.2,1);position:relative;box-shadow:0 0 8px rgba(232,200,74,.5)}
.pfill::after{content:'';position:absolute;right:-5px;top:-4px;width:14px;height:14px;background:radial-gradient(circle,var(--gold3),var(--gold));border-radius:50%;box-shadow:0 0 10px var(--gold),0 0 20px rgba(232,200,74,.6);animation:pulseOrb 1.8s ease-in-out infinite}
@keyframes pulseOrb{0%,100%{box-shadow:0 0 8px var(--gold),0 0 16px rgba(232,200,74,.5)}50%{box-shadow:0 0 16px var(--gold2),0 0 32px rgba(245,220,122,.8)}}

.qbody{max-width:640px;margin:0 auto;padding:2.2rem 1.25rem 5rem}
.dbanner{margin-bottom:2rem;padding-bottom:1.6rem;border-bottom:1px solid var(--border2);display:flex;align-items:flex-start;gap:1.3rem}
.dim-icon-box{flex-shrink:0;width:56px;height:56px;display:flex;align-items:center;justify-content:center;background:rgba(10,20,40,.85);border:1px solid var(--border);border-radius:12px;box-shadow:0 0 18px var(--glow)}
.dtag{font-family:'JetBrains Mono',monospace;font-size:.74rem;letter-spacing:.15em;color:var(--gold2);text-transform:uppercase;margin-bottom:.3rem}
.dname{font-family:'Cinzel',serif;font-size:1.75rem;font-weight:700;color:var(--text);letter-spacing:.03em;margin-bottom:.4rem;text-shadow:0 2px 12px rgba(0,0,0,.5)}
.dflavor{font-size:1.01rem;color:var(--text2);line-height:1.68;font-style:italic}

.iblock{margin-bottom:1.1rem;background:rgba(6,12,26,.88);border:1px solid var(--border2);border-radius:11px;padding:1.4rem;transition:border-color .25s,background .2s;backdrop-filter:blur(6px)}
.iblock.done{border-color:rgba(232,200,74,.32);background:rgba(8,16,32,.92)}
.imeta{font-family:'JetBrains Mono',monospace;font-size:.90rem;color:var(--text2);letter-spacing:.1em;margin-bottom:.58rem}
.itext{font-size:1.06rem;color:var(--text);line-height:1.68;margin-bottom:1.05rem;font-weight:400}
.lrow{display:flex;gap:.45rem}
.lb{flex:1;padding:.90rem 0;background:rgba(10,20,40,.85);border:1px solid rgba(140,160,180,.2);border-radius:7px;color:var(--text2);font-family:'Cinzel',serif;font-size:.97rem;font-weight:600;cursor:pointer;transition:all .18s;text-align:center;position:relative;overflow:hidden}
.lb::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(232,200,74,.18) 0%,transparent 70%);opacity:0;transition:opacity .2s}
.lb:hover{border-color:rgba(232,200,74,.5);color:var(--gold2);transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.4)}
.lb:hover::after{opacity:1}
.lb.on{background:linear-gradient(135deg,rgba(140,100,20,.6),rgba(245,220,122,.25));border-color:var(--gold);color:var(--gold2);box-shadow:0 0 14px rgba(232,200,74,.3),0 2px 8px rgba(0,0,0,.3);animation:lbPop .22s ease-out}
@keyframes lbPop{0%{transform:scale(1)}40%{transform:scale(1.1)}100%{transform:scale(1)}}
.llabels{display:flex;justify-content:space-between;font-size:.74rem;color:var(--text2);font-style:italic;margin-top:.38rem;padding:0 2px}
.note-toggle{margin-top:.9rem;font-family:'JetBrains Mono',monospace;font-size:.76rem;color:var(--text2);cursor:pointer;letter-spacing:.07em;display:inline-flex;align-items:center;gap:.45rem;transition:color .2s;padding:.3rem 0}
.note-toggle::before{content:'▸';font-size:.7rem;transition:transform .2s;color:var(--gold)}
.note-toggle.open::before{transform:rotate(90deg)}
.note-toggle:hover{color:var(--gold2)}
.narea{display:none;margin-top:.6rem}
.narea textarea{width:100%;background:rgba(8,16,36,.8);border:1px solid var(--border2);border-radius:7px;padding:.75rem .96rem;color:var(--text2);font-family:'Crimson Pro',serif;font-size:.98rem;font-style:italic;outline:none;resize:none;transition:border-color .2s}
.narea textarea:focus{border-color:var(--gold)}
.qnav{display:flex;align-items:center;justify-content:space-between;margin-top:2.2rem;gap:1rem}
.qnavinfo{font-family:'JetBrains Mono',monospace;font-size:.76rem;color:var(--text2);letter-spacing:.08em;text-align:center}

/* ── RESULTS ── */
#results{padding:0}
.rhdr{background:rgba(4,8,18,.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--border2);padding:.96rem 1.6rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:30}
.rbody{max-width:780px;margin:0 auto;padding:2rem 1.25rem 5rem}

/* Hero */
.ahero{position:relative;overflow:hidden;background:rgba(6,12,26,.9);border:1px solid var(--border);border-radius:18px;padding:3rem 2rem;margin-bottom:1.8rem;text-align:center;backdrop-filter:blur(12px)}
.ahero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% -5%,var(--glow) 0%,transparent 65%);pointer-events:none}
.ahero::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--acc),var(--acc2),var(--acc),transparent)}
.actag{font-family:'JetBrains Mono',monospace;font-size:.77rem;letter-spacing:.25em;color:var(--acc);text-transform:uppercase;margin-bottom:.8rem;text-shadow:0 0 12px var(--glow)}
.arch-icon-wrap{width:80px;height:80px;margin:0 auto 1.1rem;display:flex;align-items:center;justify-content:center;border-radius:50%;border:2px solid var(--border);background:rgba(10,20,40,.8);box-shadow:0 0 24px var(--glow),0 0 48px rgba(0,0,0,.3)}
.arch-icon-wrap svg{width:44px;height:44px}
.acname{font-family:'Cinzel',serif;font-size:clamp(1.7rem,5vw,2.8rem);font-weight:900;letter-spacing:.04em;margin-bottom:.45rem;line-height:1.1;background:linear-gradient(135deg,var(--acc),var(--acc2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 16px var(--glow))}
.acsub{font-size:.98rem;color:var(--text2);font-family:'JetBrains Mono',monospace;letter-spacing:.13em;margin-bottom:1.35rem}
.acdesc{font-size:1.09rem;color:var(--text2);line-height:1.88;max-width:540px;margin:0 auto 1.6rem;font-style:italic}
.swrow{display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;margin-bottom:1.6rem}
.swtag{padding:.32rem .92rem;border-radius:20px;font-size:1.0rem;font-family:'JetBrains Mono',monospace;letter-spacing:.04em}
.swtag.s{background:rgba(58,223,168,.1);color:#5af0b8;border:1px solid rgba(58,223,168,.28)}
.swtag.w{background:rgba(255,100,100,.08);color:#ffa0a0;border:1px solid rgba(255,100,100,.22)}
.motto{background:rgba(10,20,40,.8);border:1px solid var(--border);border-radius:11px;padding:1.4rem 1.8rem;font-size:1.08rem;color:var(--gold2);font-style:italic;line-height:1.82;position:relative;text-shadow:0 0 8px rgba(232,200,74,.2)}
.motto-q{position:absolute;top:-.5rem;left:1rem;font-family:'Cinzel',serif;font-size:3rem;color:var(--gold);opacity:.2;line-height:1}

/* Radar */
.radarcard{background:rgba(6,12,26,.88);border:1px solid var(--border);border-radius:14px;padding:1.8rem;display:flex;justify-content:center;margin-bottom:1.6rem;backdrop-filter:blur(8px)}
canvas#radar{max-width:320px;width:100%}

/* Dual index cards */
.dual-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.6rem}
@media(max-width:600px){.dual-row{grid-template-columns:1fr}}
.idx-card{background:rgba(6,12,26,.88);border:1px solid var(--border);border-radius:14px;padding:1.5rem;backdrop-filter:blur(8px);position:relative;overflow:hidden}
.idx-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--acc),transparent)}
.idx-card-title{font-family:'Cinzel',serif;font-size:1.0rem;color:var(--acc2);margin-bottom:1rem;letter-spacing:.05em;text-shadow:0 0 12px var(--glow)}
.ring-row{display:flex;align-items:center;gap:1rem;margin-bottom:.93rem}
.ring-wrap{position:relative;width:80px;height:80px;flex-shrink:0}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-lbl{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ring-val{font-family:'Cinzel',serif;font-size:1.25rem;font-weight:700;color:var(--gold2);text-shadow:0 0 8px rgba(232,200,74,.4)}
.ring-sub{font-family:'JetBrains Mono',monospace;font-size:.48rem;color:var(--text2);letter-spacing:.1em;margin-top:1px}
.ie-desc{font-size:1.0rem;color:var(--text2);line-height:1.7}
.ie-dev{margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border2);font-size:.98rem;color:var(--text2);line-height:1.65}
.ie-dev-title{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.1em;color:var(--gold);text-transform:uppercase;margin-bottom:.4rem}
.im-row-card{background:rgba(10,20,40,.7);border-radius:9px;padding:.90rem 1rem;margin-bottom:.75rem}
.im-row-card:last-child{margin-bottom:0}
.im-lbl{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.28rem}
.im-lbl.hi{color:#5af0b8}.im-lbl.lo{color:#ffa0a0}
.im-name{font-family:'Cinzel',serif;font-size:.98rem;color:var(--text);margin-bottom:.22rem}
.im-text{font-size:.91rem;color:var(--text2);line-height:1.6}

/* Scores */
.sgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(172px,1fr));gap:.75rem;margin-bottom:1.6rem}
.scard{background:rgba(6,12,26,.88);border:1px solid var(--border2);border-radius:11px;padding:1.05rem;transition:all .22s;backdrop-filter:blur(6px)}
.scard:hover{border-color:var(--border);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.4)}
.sclabel{font-family:'JetBrains Mono',monospace;font-size:.90rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text2);margin-bottom:.5rem}
.sctrack{height:5px;background:rgba(10,20,40,.9);border-radius:3px;overflow:hidden;margin-bottom:.45rem}
.scfill{height:100%;border-radius:3px;transition:width 1.4s cubic-bezier(.4,0,.2,1);position:relative}
.scfill::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent 70%,rgba(255,255,255,.3));animation:barShimmer 2s ease-in-out infinite}
@keyframes barShimmer{0%,100%{opacity:0}50%{opacity:1}}
.scval{font-family:'Cinzel',serif;font-size:1.5rem;font-weight:700;color:var(--text)}
.scval small{font-size:.7rem;color:var(--text3);font-family:'Crimson Pro',serif}

/* Compat */
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(218px,1fr));gap:.75rem;margin-bottom:1.6rem}
.ccard{background:rgba(6,12,26,.88);border:1px solid var(--border2);border-radius:11px;padding:1.05rem;backdrop-filter:blur(6px);transition:all .22s}
.ccard:hover{border-color:var(--border);transform:translateY(-1px)}
.chdr{display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem}
.cicon-box{width:34px;height:34px;display:flex;align-items:center;justify-content:center;background:rgba(10,20,40,.8);border:1px solid var(--border2);border-radius:8px;flex-shrink:0}
.cicon-box svg{width:20px;height:20px}
.cname{font-family:'Cinzel',serif;font-size:1.0rem;color:var(--text)}
.clvl{display:inline-flex;align-items:center;gap:.3rem;font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.1em;padding:.18rem .94rem;border-radius:20px;margin-bottom:.5rem}
.clvl.h{background:rgba(58,223,168,.1);color:#5af0b8}
.clvl.m{background:rgba(232,200,74,.1);color:var(--gold2)}
.creason{font-size:.98rem;color:var(--text2);line-height:1.58;font-style:italic}

/* Recs */
.rgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(228px,1fr));gap:.75rem;margin-bottom:1.6rem}
.rcard{background:rgba(6,12,26,.88);border:1px solid var(--border2);border-radius:11px;padding:1.05rem;backdrop-filter:blur(6px);transition:all .22s}
.rcard:hover{border-color:var(--border);transform:translateY(-1px)}
.rtype{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text3);margin-bottom:.32rem}
.rtitle{font-family:'Cinzel',serif;font-size:1.0rem;color:var(--gold2);margin-bottom:.4rem;text-shadow:0 0 8px rgba(232,200,74,.2)}
.rwhy{font-size:.98rem;color:var(--text2);line-height:1.57}

/* Advice */
.advcard{background:rgba(6,12,26,.88);border:1px solid var(--border);border-radius:14px;padding:1.6rem;margin-bottom:1.6rem;backdrop-filter:blur(8px)}
.advtitle{font-family:'Cinzel',serif;font-size:1rem;color:var(--acc2);margin-bottom:.93rem;text-shadow:0 0 10px var(--glow)}
.advlist{list-style:none;display:flex;flex-direction:column;gap:.7rem}
.advlist li{display:flex;align-items:flex-start;gap:.7rem;font-size:.98rem;color:var(--text2);line-height:1.65}
.advlist li::before{content:'▸';color:var(--gold);flex-shrink:0;margin-top:.1rem;text-shadow:0 0 6px rgba(232,200,74,.4)}

/* Feedback */
.fbcard{background:rgba(6,12,26,.88);border:1px solid var(--border);border-radius:14px;padding:1.8rem;margin-bottom:1.6rem;backdrop-filter:blur(8px)}
.fbcard h3{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold2);margin-bottom:1.3rem;text-shadow:0 0 10px rgba(232,200,74,.3)}
.fblrow{display:flex;gap:.45rem;margin:.5rem 0 .93rem}
.fbl{flex:1;padding:.58rem;background:rgba(10,20,40,.85);border:1px solid var(--border2);border-radius:7px;color:var(--text2);font-family:'Cinzel',serif;font-size:.90rem;cursor:pointer;transition:all .18s;text-align:center}
.fbl:hover{border-color:var(--gold);color:var(--gold2);transform:translateY(-1px)}
.fbl.on{background:var(--gold);border-color:var(--gold);color:#050b18;box-shadow:0 2px 12px rgba(232,200,74,.35)}
.fblabels{display:flex;justify-content:space-between;font-size:.76rem;color:var(--text2);font-style:italic;margin-bottom:1rem}
.fblabel{font-family:'JetBrains Mono',monospace;font-size:.74rem;color:var(--text2);letter-spacing:.08em;margin-bottom:.42rem;display:block;text-transform:uppercase}
.fbtarea{width:100%;background:rgba(8,16,36,.82);border:1px solid var(--border2);border-radius:7px;padding:.90rem .92rem;color:var(--text2);font-family:'Crimson Pro',serif;font-size:1.01rem;font-style:italic;outline:none;resize:none;transition:border-color .2s;margin-bottom:.42rem}
.fbtarea:focus{border-color:var(--gold)}
.charcount{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--text3);text-align:right}
.ract{display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;margin-top:1.6rem}

@media(max-width:520px){.qhdr{flex-wrap:wrap}.pwrap{order:3;flex:0 0 100%}.lb{font-size:1.0rem;padding:.5rem 0}.ahero{padding:2rem 1.25rem}.chip{font-size:.90rem;padding:.22rem .94rem}}

/* ── LYRA CHATBOT ── */
#lyra-section{margin-bottom:1.6rem}
.lyra-wrap{background:rgba(6,12,26,.92);border:1px solid var(--border);border-radius:16px;overflow:hidden;backdrop-filter:blur(12px);position:relative}
.lyra-wrap::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--acc),transparent)}
.lyra-head{display:flex;align-items:flex-end;gap:1.25rem;padding:0 1.5rem;background:linear-gradient(180deg,rgba(10,20,50,.6),transparent)}
.lyra-figure{flex-shrink:0;position:relative;bottom:0}
.lyra-bubble{background:rgba(10,20,50,.85);border:1px solid var(--border);border-radius:12px;padding:.9rem 1.1rem;margin:1rem 0 1rem;flex:1;font-size:.97rem;color:var(--text2);line-height:1.75;font-style:italic;position:relative}
.lyra-bubble::before{content:'';position:absolute;left:-9px;bottom:18px;border:5px solid transparent;border-right-color:var(--border)}
.lyra-bubble::after{content:'';position:absolute;left:-7px;bottom:19px;border:4px solid transparent;border-right-color:rgba(10,20,50,.85)}
.lyra-name{font-family:'Cinzel',serif;font-size:.78rem;color:var(--acc2);letter-spacing:.1em;margin-bottom:.25rem;text-shadow:0 0 8px var(--glow)}
.lyra-messages{padding:.5rem 1.5rem 0;max-height:400px;overflow-y:auto;display:flex;flex-direction:column;gap:.85rem;scroll-behavior:smooth}
.lyra-messages::-webkit-scrollbar{width:4px}
.lyra-messages::-webkit-scrollbar-track{background:transparent}
.lyra-messages::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.msg{display:flex;gap:.75rem;align-items:flex-start;animation:msgIn .3s ease-out}
@keyframes msgIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.msg.user{flex-direction:row-reverse}
.msg-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;border:1px solid var(--border)}
.msg-avatar.lyra-av{background:rgba(10,20,50,.9);box-shadow:0 0 10px var(--glow)}
.msg-avatar.user-av{background:rgba(20,30,60,.9);font-family:'Cinzel',serif;font-size:.7rem;color:var(--gold2)}
.msg-body{background:rgba(10,20,40,.85);border:1px solid var(--border2);border-radius:10px;padding:.7rem 1rem;font-size:.93rem;color:var(--text2);line-height:1.72;max-width:82%}
.msg.user .msg-body{background:rgba(20,40,80,.6);border-color:rgba(232,200,74,.15);color:var(--text)}
.msg-body.typing{display:flex;gap:4px;align-items:center;padding:.85rem 1rem}
.dot{width:7px;height:7px;border-radius:50%;background:var(--acc);animation:dotPulse 1.4s ease-in-out infinite}
.dot:nth-child(2){animation-delay:.22s}.dot:nth-child(3){animation-delay:.44s}
@keyframes dotPulse{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.lyra-input-row{display:flex;gap:.65rem;padding:1rem 1.5rem 1.25rem;border-top:1px solid var(--border2);margin-top:.5rem}
.lyra-input{flex:1;background:rgba(8,16,36,.85);border:1px solid var(--border2);border-radius:8px;padding:.65rem .9rem;color:var(--text);font-family:'Crimson Pro',serif;font-size:.97rem;outline:none;transition:border-color .2s;resize:none;height:42px;max-height:120px;overflow-y:auto;line-height:1.5}
.lyra-input:focus{border-color:var(--gold)}
.lyra-input::placeholder{color:var(--text3);font-style:italic}
.lyra-send{background:linear-gradient(135deg,#9a7420,var(--gold2));border:none;border-radius:8px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0;color:#050b18}
.lyra-send:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(232,200,74,.35)}
.lyra-send:disabled{opacity:.4;cursor:not-allowed;transform:none}
.lyra-chips{display:flex;flex-wrap:wrap;gap:.45rem;padding:0 1.5rem .9rem}
.lyra-chip{background:rgba(10,20,46,.8);border:1px solid var(--border2);border-radius:20px;padding:.28rem .78rem;font-family:'JetBrains Mono',monospace;font-size:.64rem;color:var(--text2);cursor:pointer;transition:all .18s;letter-spacing:.04em;white-space:nowrap}
.lyra-chip:hover{border-color:var(--gold);color:var(--gold2);background:rgba(20,36,80,.8)}


</style>
</head>
<body>
<canvas id="world-canvas"></canvas>
<div id="world-overlay"></div>
<div id="app">

<!-- WELCOME -->
<div id="welcome" class="screen active">
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2.5rem 1.5rem;min-height:100vh;text-align:center">
    <div class="logo-pre">◆ Instrumento de Personalidad · Prototipo v4.0 ◆</div>
    <div class="logo-main">My<span>RPG</span>Profile</div>
    <div class="logo-sub">Descubre tu clase. Conoce tu poder.</div>
    <div class="divider-gold"></div>
    <p class="pitch-text">Cada persona es un personaje único. Este instrumento revela los atributos que te definen, el arquetipo que te pertenece y el potencial que aún no has desbloqueado.</p>
    <div class="pitch-list">
      <div class="pi"><span class="pi-icon">⚔</span><span>Descubre tu clase entre 7 arquetipos únicos, con nombre adaptado a ti</span></div>
      <div class="pi"><span class="pi-icon">◈</span><span>Visualiza tus 7 atributos en un mapa de personaje interactivo</span></div>
      <div class="pi"><span class="pi-icon">✦</span><span>Conoce tu inteligencia predominante y cómo impacta tu vida</span></div>
      <div class="pi"><span class="pi-icon">▶</span><span>Recibe recomendaciones de juegos, anime y libros especialmente forjadas para ti</span></div>
      <div class="pi"><span class="pi-icon">✧</span><span>Conversa con Lyra, tu guía arcana: explora tus resultados, escribe tu historia y descubre cómo crecer</span></div>
    </div>
    <div class="rcard">
      <h2>Crea tu perfil de aventurero</h2>
      <div class="err-box" id="errbox"></div>
      <div class="row2">
        <div class="fg"><label>Nombre</label><input type="text" id="iname" placeholder="Tu nombre" autocomplete="off"></div>
        <div class="fg" style="max-width:90px"><label>Edad</label><input type="number" id="iage" placeholder="25" min="14" max="99"></div>
      </div>
      <div class="row2">
        <div class="fg">
          <label>Sexo biológico</label>
          <select id="isex"><option value="">Seleccionar</option><option value="M">Masculino</option><option value="F">Femenino</option></select>
        </div>
        <div class="fg"><label>Correo (opcional)</label><input type="email" id="iemail" placeholder="tu@correo.com"></div>
      </div>
      <p class="sex-note">El sexo biológico se usa para adaptar el género de tu arquetipo y con fines estadísticos únicamente. No influye en los resultados.</p>
      <button class="btn-p" style="width:100%" onclick="toInstr()">Comenzar aventura →</button>
    </div>
  </div>
</div>

<!-- INSTRUCTIONS -->
<div id="instructions" class="screen">
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;min-height:100vh">
    <div class="icard">
      <div class="icard-title">Los Tomos Ancestrales</div>
      <div class="icard-sub">◆ El camino del conocimiento propio ◆</div>
      <p class="epic-text">Ante ti yacen los <strong>Siete Tomos de las Disciplinas</strong>. Cada uno guarda las preguntas que, desde tiempos inmemoriales, han revelado el verdadero carácter de los viajeros. Solo quien responda con honestidad descubrirá su clase, sus poderes y sus sombras.<br><br>Responderás <strong>35 afirmaciones</strong> tomadas de dichos tomos. El viaje dura entre cinco y ocho minutos, peregrino.</p>
      <div class="chips" id="dchips"></div>
      <div class="scale-box">Para cada afirmación, indica tu nivel de acuerdo del <strong>1</strong> (Muy en desacuerdo) al <strong>5</strong> (Muy de acuerdo). Puedes dejar una nota personal en cualquier respuesta si deseas explicar tu elección.</div>
      <p class="disclaimer">No hay respuestas correctas ni incorrectas. Responde según cómo eres realmente, no como te gustaría ser. Este instrumento es un prototipo en desarrollo: los resultados son orientativos y no reemplazan evaluación profesional.</p>
      <div class="ibtns">
        <button class="btn-s" onclick="go('welcome')">← Volver</button>
        <button class="btn-p" onclick="startQ()">Comenzar →</button>
      </div>
    </div>
  </div>
</div>

<!-- QUESTIONNAIRE -->
<div id="questionnaire" class="screen">
  <div class="qhdr">
    <div class="qlogo">MyRPGProfile</div>
    <div class="pwrap">
      <div class="pmeta"><span id="plabel">Tomo I de VII</span><span id="ppct">0%</span></div>
      <div class="ptrack"><div class="pfill" id="pfill" style="width:0%"></div></div>
    </div>
  </div>
  <div class="qbody">
    <div class="dbanner">
      <div class="dim-icon-box" id="dibox"></div>
      <div>
        <div class="dtag" id="dtag">TOMO I · ATRIBUTO 1 DE 7</div>
        <div class="dname" id="dname">Voluntad</div>
        <div class="dflavor" id="dflavor"></div>
      </div>
    </div>
    <div id="iwrap"></div>
    <div class="qnav">
      <button class="btn-s" id="bprev" onclick="prevD()">← Anterior</button>
      <div class="qnavinfo" id="ninfo">0/5 respondidas</div>
      <button class="btn-p" id="bnext" onclick="nextD()">Siguiente →</button>
    </div>
  </div>
</div>

<!-- RESULTS -->
<div id="results" class="screen">
  <div class="rhdr">
    <div class="qlogo">MyRPGProfile</div>
    <button class="btn-s" onclick="newT()">Nuevo perfil</button>
  </div>
  <div class="rbody">
    <div class="ahero">
      <div class="actag">Tu clase de personaje</div>
      <div class="arch-icon-wrap" id="archIconWrap"></div>
      <div class="acname" id="acname">—</div>
      <div class="acsub" id="acsub">—</div>
      <div class="acdesc" id="acdesc">—</div>
      <div class="swrow" id="swrow"></div>
      <div class="motto"><span class="motto-q">"</span><span id="motto">—</span></div>
    </div>
    <div class="sep">Mapa de atributos</div>
    <div class="radarcard"><canvas id="radar" width="320" height="320"></canvas></div>
    <div class="sep">Índices derivados</div>
    <div class="dual-row">
      <div class="idx-card">
        <div class="idx-card-title">Inteligencia Emocional</div>
        <div class="ring-row">
          <div class="ring-wrap">
            <svg width="80" height="80" viewBox="0 0 80 80"><circle cx="40" cy="40" r="33" fill="none" stroke="rgba(232,200,74,.12)" stroke-width="6"/><circle id="iearc" cx="40" cy="40" r="33" fill="none" stroke="var(--gold)" stroke-width="6" stroke-dasharray="207" stroke-dashoffset="207" stroke-linecap="round" style="transition:stroke-dashoffset 1.7s cubic-bezier(.4,0,.2,1)"/></svg>
            <div class="ring-lbl"><span class="ring-val" id="ieval">—</span><span class="ring-sub">IE</span></div>
          </div>
          <div class="ie-desc" id="iedesc">—</div>
        </div>
        <div class="ie-dev"><div class="ie-dev-title">▸ Cómo desarrollarla</div><div id="iedev">—</div></div>
      </div>
      <div class="idx-card">
        <div class="idx-card-title">Inteligencias Múltiples</div>
        <div id="imblock"></div>
      </div>
    </div>
    <div class="sep">Atributos detallados</div>
    <div class="sgrid" id="sgrid"></div>
    <div class="sep">Compatibilidad de grupo</div>
    <div class="cgrid" id="cgrid"></div>
    <div class="sep">Videojuegos para tu clase</div>
    <div class="rgrid" id="ggrid"></div>
    <div class="sep">Anime para tu clase</div>
    <div class="rgrid" id="agrid"></div>
    <div class="sep">Libros para tu clase</div>
    <div class="rgrid" id="bgrid"></div>
    <div class="sep">Cómo combatir la vida según tu clase</div>
    <div class="advcard" id="advcard"></div>
    <div class="sep">Tu opinión importa</div>
    <div class="fbcard">
      <h3>¿Esta interpretación te representa?</h3>
      <span class="fblabel">Indica tu nivel de acuerdo</span>
      <div class="fblrow"><button class="fbl" onclick="setFb(this,1)">1</button><button class="fbl" onclick="setFb(this,2)">2</button><button class="fbl" onclick="setFb(this,3)">3</button><button class="fbl" onclick="setFb(this,4)">4</button><button class="fbl" onclick="setFb(this,5)">5</button></div>
      <div class="fblabels"><span>No me representa</span><span>Me representa totalmente</span></div>
      <span class="fblabel">¿Por qué? (opcional)</span>
      <textarea class="fbtarea" id="fbwhy" rows="3" maxlength="300" placeholder="Cuéntanos tu experiencia..." oninput="uc(this,'cw',300)"></textarea>
      <div class="charcount" id="cw">300 caracteres restantes</div>
      <span class="fblabel" style="margin-top:1rem">Sugerencias (opcional)</span>
      <textarea class="fbtarea" id="fbsug" rows="3" maxlength="400" placeholder="¿Qué agregarías o cambiarías?" oninput="uc(this,'cs',400)"></textarea>
      <div class="charcount" id="cs">400 caracteres restantes</div>
    </div>
    <div class="sep">Tu guía arcana</div>
    <div id="lyra-section">
      <!-- Lyra chatbot injected here by JS -->
    </div>
    <div class="ract">
      <button class="btn-s" onclick="window.print()">Imprimir perfil</button>
      <button class="btn-s" onclick="newT()">Nuevo perfil</button>
    </div>
  </div>
</div>
</div>

<script>
// ═══════════════ STARRY SKY BACKGROUND ═══════════════
(function(){
  const cv=document.getElementById('world-canvas');
  const ctx=cv.getContext('2d');
  let W,H,t=0;

  const STARS=[];
  function mkStars(){
    STARS.length=0;
    for(let i=0;i<260;i++){
      STARS.push({
        x:Math.random()*W, y:Math.random()*H,
        r: Math.random()<.06 ? Math.random()*.9+.9   // bright
          :Math.random()<.25 ? Math.random()*.5+.4   // medium
          : Math.random()*.25+.1,                    // dim
        phase: Math.random()*Math.PI*2,
        speed: Math.random()*.0012+.0004,
        base:  Math.random()*.45+.1,
        amp:   Math.random()*.35+.1,
        color: Math.random()<.12 ? [200,220,255]
              :Math.random()<.08 ? [255,240,200]
              :[220,230,255]
      });
    }
  }

  function resize(){W=cv.width=window.innerWidth;H=cv.height=window.innerHeight;mkStars()}

  function frame(ts){
    t=ts;
    ctx.clearRect(0,0,W,H);

    // Deep night gradient
    const g=ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0,'#020510');
    g.addColorStop(.35,'#040a1c');
    g.addColorStop(.7,'#050d14');
    g.addColorStop(1,'#030810');
    ctx.fillStyle=g;ctx.fillRect(0,0,W,H);

    // Faint nebula clouds
    const n1=ctx.createRadialGradient(W*.3,H*.22,0,W*.3,H*.22,W*.32);
    n1.addColorStop(0,'rgba(60,80,160,.06)');n1.addColorStop(1,'transparent');
    ctx.fillStyle=n1;ctx.fillRect(0,0,W,H);
    const n2=ctx.createRadialGradient(W*.75,H*.4,0,W*.75,H*.4,W*.28);
    n2.addColorStop(0,'rgba(80,40,130,.05)');n2.addColorStop(1,'transparent');
    ctx.fillStyle=n2;ctx.fillRect(0,0,W,H);

    // Stars — progressive glow
    STARS.forEach(s=>{
      const osc=Math.sin(t*s.speed+s.phase);
      const opacity=Math.max(.04, Math.min(.98, s.base + s.amp*osc));
      const glow=s.r>0.7 ? (s.r*2.5*(0.5+0.5*osc)) : 0;

      if(glow>0){
        const halo=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,glow*4);
        halo.addColorStop(0,`rgba(${s.color[0]},${s.color[1]},${s.color[2]},${opacity*.35})`);
        halo.addColorStop(1,'transparent');
        ctx.fillStyle=halo;ctx.fillRect(s.x-glow*4,s.y-glow*4,glow*8,glow*8);
      }
      ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(${s.color[0]},${s.color[1]},${s.color[2]},${opacity})`;
      ctx.fill();
    });

    requestAnimationFrame(frame);
  }

  resize();window.addEventListener('resize',resize);
  requestAnimationFrame(frame);
})();

// ═══════════════ SVG ICONS ═══════════════
const ICONS={
  voluntad:`<svg width="36" height="36" viewBox="0 0 40 40" fill="none"><path d="M20 8 L24 14 L30 14 L25 19 L27 26 L20 22 L13 26 L15 19 L10 14 L16 14 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><line x1="20" y1="26" x2="20" y2="34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
